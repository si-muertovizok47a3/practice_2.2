import json
import requests
import os

SAVE_FILE = "save.json"


def load_rates():
    try:
        response = requests.get("https://www.cbr-xml-daily.ru/daily_json.js")
        data = response.json()
        return data["Valute"]
    except:
        print("Ошибка загрузки курса валют!")
        return None


def load_groups():
    if os.path.exists(SAVE_FILE):
        with open(SAVE_FILE, "r", encoding="utf-8") as f:
            return json.load(f)
    return {}


def save_groups(groups):
    with open(SAVE_FILE, "w", encoding="utf-8") as f:
        json.dump(groups, f, ensure_ascii=False, indent=2)

def show_all_currencies(rates):
    print("\n" + "=" * 60)
    print(f"{'Код':<8} {'Название':<35} {'Курс':>10}")
    print("=" * 60)
    for code, info in rates.items():
        print(f"{code:<8} {info['Name']:<35} {info['Value']:>10.2f}")
    print("=" * 60)

def show_currency(rates, code):
    code = code.upper()
    if code in rates:
        info = rates[code]
        print(f"\n{info['Name']} ({code})")
        print(f"Курс: {info['Value']:.2f} руб.")
        print(f"Номинал: {info['Nominal']}")
    else:
        print(f"\nВалюта {code} не найдена!")


def show_groups(groups):
    if not groups:
        print("\nНет созданных групп!")
        return

    print("\n" + "=" * 50)
    for group_name, currencies in groups.items():
        print(f"\n📁 {group_name}:")
        if currencies:
            for code in currencies:
                print(f"  - {code}")
        else:
            print("  (пусто)")
    print("=" * 50)

def add_to_group(groups, rates):
    group = input("Введите название группы: ")
    code = input("Введите код валюты (например, USD, EUR): ").upper()

    if code not in rates:
        print(f"Валюта {code} не найдена!")
        return

    if group not in groups:
        groups[group] = []

    if code in groups[group]:
        print(f"Валюта {code} уже в группе {group}!")
    else:
        groups[group].append(code)
        save_groups(groups)
        print(f"Валюта {code} добавлена в группу {group}!")


def remove_from_group(groups):
    if not groups:
        print("Нет созданных групп!")
        return

    show_groups(groups)
    group = input("\nВведите название группы: ")

    if group not in groups:
        print(f"Группа {group} не найдена!")
        return

    if not groups[group]:
        print(f"Группа {group} пуста!")
        return

    print(f"\nВалюты в группе {group}:")
    for i, code in enumerate(groups[group], 1):
        print(f"{i}. {code}")

    try:
        idx = int(input("Введите номер валюты для удаления: ")) - 1
        if 0 <= idx < len(groups[group]):
            removed = groups[group].pop(idx)
            save_groups(groups)
            print(f"Валюта {removed} удалена из группы {group}!")
        else:
            print("Неверный номер!")
    except:
        print("Ошибка ввода!")

def create_group(groups):
    name = input("Введите название новой группы: ")
    if name in groups:
        print(f"Группа {name} уже существует!")
    else:
        groups[name] = []
        save_groups(groups)
        print(f"Группа {name} создана!")


def main():
    rates = load_rates()
    if not rates:
        return

    groups = load_groups()

    while True:
        print("\n" + "=" * 40)
        print("     КУРСЫ ВАЛЮТ")
        print("=" * 40)
        print("1. Все курсы валют")
        print("2. Курс конкретной валюты")
        print("3. Мои группы")
        print("4. Создать группу")
        print("5. Добавить валюту в группу")
        print("6. Удалить валюту из группы")
        print("7. Выход")
        print("=" * 40)

        choice = input("Выберите действие: ")

        if choice == "1":
            show_all_currencies(rates)
        elif choice == "2":
            code = input("Введите код валюты (USD, EUR и т.д.): ")
            show_currency(rates, code)
        elif choice == "3":
            show_groups(groups)
        elif choice == "4":
            create_group(groups)
        elif choice == "5":
            add_to_group(groups, rates)
        elif choice == "6":
            remove_from_group(groups)
        elif choice == "7":
            print("До свидания!")
            break
        else:
            print("Неверный выбор!")


if __name__ == "__main__":
    main()
